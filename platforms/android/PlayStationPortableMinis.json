{
  "id": "pspminis",
  "name": "PlayStation Portable Minis",
  "external_ids": {
    "screenscraper": [
      61
    ],
    "igdb": [
      38
    ],
    "thegamesdb": [
      13
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "chd",
    "cso",
    "elf",
    "iso",
    "pbp",
    "prx"
  ],
  "emulators": [
    {
      "id": "pspminis.org.ppsspp.ppsspp",
      "name": "PPSSPP",
      "executable": [
        "org.ppsspp.ppsspp/.PpssppActivity"
      ],
      "filetypes": [
        "cso",
        "chd",
        "elf",
        "iso",
        "pbp",
        "prx"
      ],
      "action": "android.intent.action.VIEW",
      "categories": [
        "android.intent.category.DEFAULT"
      ],
      "args": [
        "{FILE_URI}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top",
        "--activity-no-history"
      ]
    },
    {
      "id": "pspminis.org.ppsspp.ppssppgold",
      "name": "PPSSPP Gold",
      "executable": [
        "org.ppsspp.ppssppgold/org.ppsspp.ppsspp.PpssppActivity"
      ],
      "filetypes": [
        "cso",
        "chd",
        "elf",
        "iso",
        "pbp",
        "prx"
      ],
      "action": "android.intent.action.VIEW",
      "categories": [
        "android.intent.category.DEFAULT"
      ],
      "args": [
        "{FILE_URI}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top",
        "--activity-no-history"
      ]
    },
    {
      "id": "pspminis.org.ppsspp.ppsspplegacy",
      "name": "PPSSPP Legacy",
      "executable": [
        "org.ppsspp.ppsspplegacy/org.ppsspp.ppsspp.PpssppActivity"
      ],
      "filetypes": [
        "cso",
        "chd",
        "elf",
        "iso",
        "pbp",
        "prx"
      ],
      "action": "android.intent.action.VIEW",
      "categories": [
        "android.intent.category.DEFAULT"
      ],
      "args": [
        "{FILE_URI}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top",
        "--activity-no-history"
      ]
    },
    {
      "id": "pspminis.ra64.ppsspp",
      "name": "PPSSPP (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "cso",
        "chd",
        "elf",
        "iso",
        "pbp",
        "prx"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "ppsspp"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}