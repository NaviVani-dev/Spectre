{
  "id": "apple2",
  "name": "Apple II",
  "external_ids": {
    "retroachievements": [
      38
    ],
    "screenscraper": [
      86
    ],
    "igdb": [
      75
    ],
    "thegamesdb": [
      4942
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "cmd"
  ],
  "emulators": [
    {
      "id": "appleii.ra64.mess",
      "name": "Mamemess (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "cmd"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "mamemess"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}