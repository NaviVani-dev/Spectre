  "emulators": [
    {
      "id": "satellaview.com.explusalpha.Snes9xPlus",
      "name": "Snes9x EX",
      "executable": [
        "com.explusalpha.Snes9xPlus/com.imagine.BaseActivity"
      ],
      "filetypes": [
        "bml",
        "bs",
        "bsx",
        "dx2",
        "fig",
        "gb",
        "gbc",
        "gd3",
        "gd7",
        "rom",
        "sfc",
        "smc",
        "st",
        "swc"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ]
    },
    {
      "id": "satellaview.ra64.snes9x",
      "name": "Snes9x (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "bs",
        "fig",
        "sfc",
        "smc",
        "st",
        "swc",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "snes9x"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
