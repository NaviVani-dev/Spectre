    "7z",
    "bml",
    "bs",
    "bsx",
    "dx2",
    "fig",
    "gb",
    "gbc",
    "gd3",
    "gd7",
    "rom",
    "sfc",
    "smc",
    "st",
    "swc",
    "zip"
