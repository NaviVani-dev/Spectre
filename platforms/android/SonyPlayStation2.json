      ],
      "filetypes": [
        "bin",
        "cso",
        "elf",
        "iso",
        "isz"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "play"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
