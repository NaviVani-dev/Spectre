{
  "id": "atari2600",
  "name": "Atari 2600",
  "external_ids": {
    "retroachievements": [
      25
    ],
    "screenscraper": [
      26
    ],
    "igdb": [
      59
    ],
    "thegamesdb": [
      22
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "7z",
    "a26",
    "bin",
    "zip"
  ],
  "emulators": [
    {
      "id": "atari2600.com.explusalpha.A2600Emu",
      "name": "com.explusalpha.A2600Emu",
      "executable": [
        "com.explusalpha.A2600Emu/com.imagine.BaseActivity"
      ],
      "filetypes": [
        "a26",
        "bin"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ]
    },
    {
      "id": "atari2600.com.androidemu.atari",
      "name": "com.androidemu.atari",
      "executable": [
        "com.androidemu.atari/.EmulatorActivity"
      ],
      "filetypes": [
        "a26",
        "bin"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "atari2600.ra64.stella",
      "name": "Stella (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "a26",
        "bin",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "stella"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "atari2600.ra64.stella2014",
      "name": "Stella 2014 (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "a26",
