  "fileRegex": "^(?!(?:\\._|\\.).*).*(?<!bin)$",
  "filetypes": [
    "7z",
    "bin",
    "cdi",
    "chd",
    "cue",
    "elf",
    "gdi",
    "lst",
    "m3u",
    "zip"
  ],
  "emulators": [
    {
      "id": "dreamcast.io.recompiled.redream",
      "name": "Redream",
      "executable": [
        "io.recompiled.redream/.MainActivity"
      ],
      "filetypes": [
        "7z",
        "bin",
        "cdi",
        "chd",
        "cue",
        "elf",
        "gdi",
        "lst",
        "m3u",
        "zip"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ]
    },
    {
      "id": "dreamcast.com.reicast.emulator",
      "name": "Reicast",
      "executable": [
        "com.reicast.emulator/.MainActivity"
      ],
      "filetypes": [
        "7z",
        "bin",
        "cdi",
        "chd",
        "cue",
        "elf",
        "gdi",
        "lst",
        "zip"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ]
    },
    {
      "id": "dreamcast.com.flycast.emulator",
      "name": "Flycast",
      "executable": [
        "com.flycast.emulator/com.flycast.emulator.MainActivity"
      ],
      "filetypes": [
        "7z",
        "bin",
        "cdi",
        "chd",
        "cue",
        "elf",
        "gdi",
        "lst",
        "zip"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ]
    },
    {
      "id": "dreamcast.com.flycast.emulator",
      "name": "Flycast (Dev Build)",
      "executable": [
        "com.flycast.emulator/com.flycast.emulator.MainActivity"
      ],
      "filetypes": [
        "7z",
        "bin",
        "cdi",
        "chd",
        "cue",
        "elf",
        "gdi",
        "lst",
        "zip"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ]
    },
    {
      "id": "dreamcast.ra64.flycast",
      "name": "Flycast (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "7z",
        "bin",
        "cdi",
        "chd",
        "cue",
        "elf",
        "gdi",
        "lst",
        "m3u",
        "zip"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "flycast"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
