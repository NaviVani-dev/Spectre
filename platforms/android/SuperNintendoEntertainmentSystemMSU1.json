  "fileRegex": "^(?!(?:\\._|\\.).*).*(?<!bml)$",
  "filetypes": [
    "7z",
    "bml",
    "bs",
    "bsx",
    "dx2",
    "fig",
    "gb",
    "gbc",
    "gd3",
    "gd7",
