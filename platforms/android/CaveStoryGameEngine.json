{
  "id": "cavestory",
  "name": "Cave Story Game Engine",
  "external_ids": {},
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "exe"
  ],
  "emulators": [
    {
      "id": "cavestory.ra64.nxengine",
      "name": "Nxengine (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "exe"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "nxengine"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "cavestory.ra64.drs",
      "name": "Doukutsu Rs (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "exe"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "doukutsu_rs"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}