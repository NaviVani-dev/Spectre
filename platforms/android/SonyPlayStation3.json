{
  "id": "ps3",
  "name": "Sony PlayStation 3",
  "external_ids": {
    "screenscraper": [
      59
    ],
    "igdb": [
      9
    ],
    "thegamesdb": [
      12
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "iso",
    "ps3folder"
  ],
  "emulators": [
    {
      "id": "ps3.aenu.aps3e",
      "name": "aPS3e",
      "executable": [
        "aenu.aps3e/aenu.aps3e.EmulatorActivity"
      ],
      "filetypes": [
        "iso"
      ],
      "action": "aenu.intent.action.APS3E",
      "args": [
        {
          "key": "iso_uri",
          "value": "{FILE_URI}"
        }
      ]
    },
    {
      "id": "ps3.aenu.aps3e.folder",
      "name": "aPS3e (Folder Style)",
      "executable": [
        "aenu.aps3e/aenu.aps3e.EmulatorActivity"
      ],
      "filetypes": [
        "ps3folder"
      ],
      "action": "aenu.intent.action.APS3E",
      "args": [
        {
          "key": "game_dir",
          "value": "{tags.ps3folder}"
        }
      ]
    }
  ]
}