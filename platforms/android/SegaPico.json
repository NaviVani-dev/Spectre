{
  "id": "pico",
  "name": "Sega Pico",
  "external_ids": {
    "retroachievements": [
      68
    ],
    "screenscraper": [
      250
    ],
    "igdb": [
      339
    ],
    "thegamesdb": [
      4958
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "7z",
    "md",
    "zip"
  ],
  "emulators": [
    {
      "id": "pico.ra64.picodrive",
      "name": "PicoDrive (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "md",
        "7z",
        "zip"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "picodrive"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}