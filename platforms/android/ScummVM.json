{
  "id": "scummvm",
  "name": "ScummVM",
  "external_ids": {
    "screenscraper": [
      123
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "dpt",
    "scummvm",
    "sh",
    "svm"
  ],
  "emulators": [
    {
      "id": "scummvm.org.scummvm.scummvm",
      "name": "ScummVM",
      "executable": [
        "org.scummvm.scummvm/org.scummvm.scummvm.SplashActivity"
      ],
      "filetypes": [
        "dpt"
      ],
      "action": "android.intent.action.MAIN",
      "categories": [
        "android.intent.category.LAUNCHER"
      ],
      "args": [
        "{tags.scummvm_id}"
      ]
    },
    {
      "id": "scummvm.org.scummvm.scummvm.debug",
      "name": "ScummVM (Debug Build)",
      "executable": [
        "org.scummvm.scummvm.debug/org.scummvm.scummvm.SplashActivity"
      ],
      "filetypes": [
        "dpt"
      ],
      "action": "android.intent.action.MAIN",
      "categories": [
        "android.intent.category.LAUNCHER"
      ],
      "args": [
        "{tags.scummvm_id}"
      ]
    },
    {
      "id": "scummvm.ra64.scummvm",
      "name": "ScummVM (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "sh",
        "svm",
        "scummvm"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "scummvm"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}