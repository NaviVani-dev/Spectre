{
  "id": "gamegear",
  "name": "Sega Game Gear",
  "external_ids": {
    "retroachievements": [
      15
    ],
    "screenscraper": [
      21
    ],
    "igdb": [
      35
    ],
    "thegamesdb": [
      20
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "32x",
    "68k",
    "7z",
    "bin",
    "bms",
    "chd",
    "col",
    "cue",
    "gen",
    "gg",
    "iso",
    "m3u",
    "md",
    "mdx",
    "pco",
    "rom",
    "sg",
    "sgd",
    "smd",
    "sms",
    "zip"
  ],
  "emulators": [
    {
      "id": "gamegear.com.androidemu.gg",
      "name": "Gearoid",
      "executable": [
        "com.androidemu.gg/.EmulatorActivity"
      ],
      "filetypes": [
        "bin",
        "bms",
        "col",
        "gg",
        "rom",
        "sg",
        "sms"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "gamegear.com.fms.mg",
      "name": "MasterGear",
      "executable": [
        "com.fms.mg/com.fms.emulib.MainActivity"
      ],
      "filetypes": [
        "gg",
        "sms"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top",
        "--activity-no-history"
      ]
    },
    {
      "id": "gamegear.it.dbtecno.pizzaboyscpro",
      "name": "Pizza Boy SC Pro",
      "executable": [
        "it.dbtecno.pizzaboyscpro/.MainActivity"
      ],
      "filetypes": [
        "gg",
        "zip"
      ],
      "args": [
        {
          "key": "rom_uri",
          "value": "{FILE_PATH}"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "gamegear.ra64.genesis_plus_gx",
      "name": "Genesis Plus GX (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "68k",
        "bin",
        "chd",
        "cue",
        "gen",
        "gg",
        "iso",
        "md",
        "mdx",
        "sg",
        "smd",
        "sms",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "genesis_plus_gx"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
