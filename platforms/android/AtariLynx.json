{
  "id": "atarilynx",
  "name": "Atari Lynx",
  "external_ids": {
    "retroachievements": [
      13
    ],
    "screenscraper": [
      28
    ],
    "igdb": [
      61
    ],
    "thegamesdb": [
      4924
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "7z",
    "lnx",
    "o",
    "zip"
  ],
  "emulators": [
    {
      "id": "lynx.com.explusalpha.LynxEmu",
      "name": "com.explusalpha.LynxEmu",
      "executable": [
        "com.explusalpha.LynxEmu/com.imagine.BaseActivity"
      ],
      "filetypes": [
        "lnx",
        "o",
        "zip",
        "7z"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ]
    },
    {
      "id": "lynx.ra64.mednafen_lynx",
      "name": "Mednafen Lynx (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "lnx",
        "o",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "mednafen_lynx"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "lynx.ra64.handy",
      "name": "Handy (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
