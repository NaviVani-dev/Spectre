      ],
      "filetypes": [
        "bat",
        "com",
        "cue",
        "dosz",
        "exe",
        "ima",
        "img",
        "ins",
        "iso",
        "m3u",
        "m3u8",
        "vhd",
        "zip"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "dosbox_pure"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
