{
  "id": "pcfx",
  "name": "NEC PC-FX",
  "external_ids": {
    "retroachievements": [
      49
    ],
    "screenscraper": [
      72
    ],
    "igdb": [
      274
    ],
    "thegamesdb": [
      4930
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "ccd",
    "chd",
    "cue",
    "toc"
  ],
  "emulators": [
    {
      "id": "pcfx.ra64.mednafen_pcfx",
      "name": "Mednafen PCFX (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "cue",
        "ccd",
        "toc",
        "chd"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "mednafen_pcfx"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}