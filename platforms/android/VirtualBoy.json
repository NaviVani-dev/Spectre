{
  "id": "virtualboy",
  "name": "Virtual Boy",
  "external_ids": {
    "retroachievements": [
      28
    ],
    "screenscraper": [
      11
    ],
    "igdb": [
      87
    ],
    "thegamesdb": [
      4918
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "7z",
    "bin",
    "vb",
    "vboy",
    "zip"
  ],
  "emulators": [
    {
      "id": "virtualboy.com.simongellis.vvb",
      "name": "vvs",
      "executable": [
        "com.simongellis.vvb/com.simongellis.vvb.MainActivity"
      ],
      "filetypes": [
        "vb",
        "zip"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ]
    },
    {
      "id": "virtualboy.ra64.mednafen_vb",
      "name": "Mednafen VB (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "bin",
        "vb",
        "vboy",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "mednafen_vb"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}