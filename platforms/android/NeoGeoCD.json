{
  "id": "neogeocd",
  "name": "Neo Geo CD",
  "external_ids": {
    "retroachievements": [
      56
    ],
    "screenscraper": [
      70
    ],
    "igdb": [
      136
    ],
    "thegamesdb": [
      4956
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "chd",
    "cue"
  ],
  "emulators": [
    {
      "id": "neogeocd.ra64.neocd",
      "name": "Neocd (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "chd",
        "cue"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "neocd"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "neogeocd.ra64.fbneo",
      "name": "FBNeo (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "cue"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "fbneo"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}