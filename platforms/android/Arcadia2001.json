{
  "id": "arcadia",
  "name": "Arcadia 2001",
  "external_ids": {
    "retroachievements": [
      73
    ],
    "screenscraper": [
      94
    ],
    "igdb": [
      473
    ],
    "thegamesdb": [
      4963
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "cmd",
    "zip"
  ],
  "emulators": [
    {
      "id": "arcadia.com.amigan.droidarcadia",
      "name": "DroidArcadia",
      "executable": [
        "com.amigan.droidarcadia/.MainActivity"
      ],
      "filetypes": [
        "zip"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "arcadia.ra64.mess",
      "name": "Mamemess (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "cmd"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "mamemess"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}