{
  "id": "pokemini",
  "name": "Pokemon Mini",
  "external_ids": {
    "retroachievements": [
      24
    ],
    "screenscraper": [
      211
    ],
    "igdb": [
      166
    ],
    "thegamesdb": [
      4957
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "7z",
    "min",
    "zip"
  ],
  "emulators": [
    {
      "id": "pokemini.ra64.pokemini",
      "name": "Pokemini (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "min",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "pokemini"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}