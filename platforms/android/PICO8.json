{
  "id": "pico8",
  "name": "PICO-8",
  "external_ids": {
    "screenscraper": [
      234
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "p8",
    "png"
  ],
  "emulators": [
    {
      "id": "pico8.io.wip.pico8",
      "name": "Pico8 Wrapper (NaviVani's Fork)",
      "executable": [
        "io.wip.pico8/com.godot.game.GodotApp"
      ],
      "filetypes": [
        "png"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        {
          "key": "GAME",
          "value": "{FILE_PATH}"
        }
      ]
    },
    {
      "id": "pico8.me.dt2dev.infinity",
      "name": "Infinity P8 Player",
      "executable": [
        "me.dt2dev.infinity/me.dt2dev.infinity.SchemeActivity"
      ],
      "filetypes": [
        "p8",
        "png"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ]
    },
    {
      "id": "pico8.ra64.fake08",
      "name": "Fake08 (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "p8",
        "png"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "fake08"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "pico8.ra64.retro8",
      "name": "Retro8 (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "p8",
        "png"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "retro8"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}