{
  "id": "videos",
  "name": "Video Player",
  "external_ids": {},
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "avi",
    "m4a",
    "mkv",
    "mov",
    "mp4",
    "mpeg",
    "mpg",
    "webm"
  ],
  "emulators": [
    {
      "id": "videos.org.videolan.vlc",
      "name": "VLC for Android",
      "executable": [
        "org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity"
      ],
      "filetypes": [
        "mp4",
        "avi",
        "mpg",
        "mpeg",
        "mov",
        "mkv",
        "webm",
        "m4a"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "videos.is.xyz.mpv",
      "name": "mpv-android",
      "executable": [
        "is.xyz.mpv/is.xyz.mpv.MPVActivity"
      ],
      "filetypes": [
        "mp4",
        "avi",
        "mpg",
        "mpeg",
        "mov",
        "mkv",
        "webm",
        "m4a"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "videos.com.mxtech.videoplayer.ad",
      "name": "MXPlayer (Ad-sipported)",
      "executable": [
        "com.mxtech.videoplayer.ad/.ActivityScreen"
      ],
      "filetypes": [
        "mp4",
        "avi",
        "mpg",
        "mpeg",
        "mov",
        "mkv",
        "webm",
        "m4a"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "videos.com.mxtech.videoplayer.pro",
      "name": "MXPlayer Pro",
      "executable": [
        "com.mxtech.videoplayer.pro/.ActivityScreen"
      ],
      "filetypes": [
        "mp4",
        "avi",
        "mpg",
        "mpeg",
        "mov",
        "mkv",
        "webm",
        "m4a"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "videos.ra64.ffmpeg",
      "name": "Ffmpeg (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "mp4",
        "avi",
        "mpg",
        "mpeg",
        "mov",
        "mkv",
        "webm",
        "m4a"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "ffmpeg"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}