{
  "id": "fds",
  "name": "Famicom Disk System",
  "external_ids": {
    "retroachievements": [
      7
    ],
    "screenscraper": [
      106
    ],
    "igdb": [
      51
    ],
    "thegamesdb": [
      4936
    ]
  },
  "fileRegex": "^(?!(?:\\._|\\.).*).*$",
  "filetypes": [
    "7z",
    "bin",
    "fds",
    "nes",
    "nsf",
    "qd",
    "rom",
    "unf",
    "unif",
    "zip"
  ],
  "emulators": [
    {
      "id": "fds.com.explusalpha.NesEmu",
      "name": "NES.emu",
      "executable": [
        "com.explusalpha.NesEmu/com.imagine.BaseActivity"
      ],
      "filetypes": [
        "bin",
        "fds",
        "nes",
        "nsf",
        "qd",
        "rom",
        "unf",
        "unif"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_URI}"
      ]
    },
    {
      "id": "fds.com.androidemu.nes",
      "name": "Nesoid",
      "executable": [
        "com.androidemu.nes/.EmulatorActivity"
      ],
      "filetypes": [
        "bin",
        "fds",
        "nes",
        "nsf",
        "qd",
        "rom",
        "unf",
        "unif"
      ],
      "action": "android.intent.action.VIEW",
      "args": [
        "{FILE_PATH}"
      ]
    },
    {
      "id": "fds.ra64.nestopia",
      "name": "Nestopia (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "fds",
        "nes",
        "unf",
        "unif",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "nestopia"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "fds.ra64.fceumm",
      "name": "FCEUmm (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "fds",
        "nes",
        "unf",
        "unif",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "fceumm"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    },
    {
      "id": "fds.ra64.mesen",
      "name": "Mesen (RetroArch)",
      "executable": [
        "com.retroarch.aarch64/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch.ra32/com.retroarch.browser.retroactivity.RetroActivityFuture",
        "com.retroarch/com.retroarch.browser.retroactivity.RetroActivityFuture"
      ],
      "filetypes": [
        "fds",
        "nes",
        "unf",
        "unif",
        "zip",
        "7z"
      ],
      "args": [
        {
          "key": "ROM",
          "value": "{FILE_PATH}"
        },
        {
          "key": "LIBRETRO",
          "value": "mesen"
        },
        {
          "key": "CONFIGFILE",
          "value": "/storage/emulated/0/Android/data/{EMULATOR_EXECUTABLE}/files/retroarch.cfg"
        }
      ],
      "flags": [
        "--activity-clear-task",
        "--activity-clear-top"
      ]
    }
  ]
}